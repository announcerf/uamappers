# Environment
# dev | prod
UAMAPPERS_ENV=dev

# Logging
RUST_LOG=info

# Postgres
# Use localhost when running Postgres outside docker.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=uamappers

# API
API_BIND=0.0.0.0:8080

# Worker
OSU_CLIENT_ID=123456
OSU_CLIENT_SECRET=replace_me

# Worker: progress logs (0 disables)
WORKER_PROGRESS_EVERY=25

# Worker jobs
RUN_DISCOVERY=1
ENRICH_USERS=1
ENRICH_BEATMAPSETS=1

# Worker: osu! `user_beatmapsets` request limit
ENRICH_BEATMAPSETS_PAGE_SIZE=50

# Worker: discovery scan (rate-limit + pagination)
SCAN_PAGE_DELAY_MS=500
SCAN_MAX_PAGES=10
SCAN_BATCH_SIZE=50
SCAN_FORCE_RESCAN=0
SCAN_RESUME_FROM_CHECKPOINT=1
SCAN_OLDEST_FIRST=0
