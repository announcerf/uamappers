UAMAPPERS_ENV=dev
RUST_LOG=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=uamappers
POSTGRES_PASSWORD=
POSTGRES_DB=uamappers

API_BIND=0.0.0.0:8080

OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

WORKER_PROGRESS_EVERY=25
RUN_DISCOVERY=1
ENRICH_USERS=1
ENRICH_BEATMAPSETS=1
ENRICH_BEATMAPSETS_PAGE_SIZE=500
SCAN_PAGE_DELAY_MS=500
SCAN_MAX_PAGES=10
SCAN_BATCH_SIZE=50
SCAN_FORCE_RESCAN=0
SCAN_RESUME_FROM_CHECKPOINT=0
SCAN_OLDEST_FIRST=0
